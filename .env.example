# Giao diện kết nối GHN API
GHN_BASE_URL=https://online-gateway.ghn.vn/shiip/public-api
GHN_SHOP_ID=your-ghn-shop-id-here
GHN_TOKEN=your-ghn-token-here

# Webhook xây dựng tự động của Netlify (để tự đồng bộ hóa dữ liệu)
NETLIFY_BUILD_HOOK_URL=https://api.netlify.com/build_hooks/your-build-hook-id

# Khóa bí mật Captcha (tùy chọn)
CAPTCHA_SECRET=some-long-random-secret-for-captcha

# Cấu hình lưu Đánh giá đơn hàng vào Google Sheets qua Apps Script Web App
# Thay đổi URL dưới đây thành URL Web App đã deploy của bạn
GOOGLE_REVIEW_WEB_APP_URL=https://script.google.com/macros/s/your-google-script-id/exec

# Mã bí mật dùng chung (phải trùng khớp với giá trị SHARED_SECRET đã cấu hình trong Apps Script)
GOOGLE_REVIEW_SHARED_SECRET=hannah-olala-review-secret-2026
